# Copiar a .env.local (no subir .env.local a git).
# Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Usa la anon / public key (JWT "anon") O la clave publishable nueva:
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=...  # alternativa si tu proyecto usa publishable key
